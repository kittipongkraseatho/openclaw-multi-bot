server {
    listen ${PORT};
    listen [::]:${PORT};
    server_name _;
    resolver ${NGINX_RESOLVER} valid=30s ipv6=off;

    root /usr/share/nginx/html;
    index index.html;
    set $gateway_ws  http://${GATEWAY_HOST}:18789;
    set $gateway_api http://${GATEWAY_HOST}:18790;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /ws {
        proxy_pass         $gateway_ws;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade               $http_upgrade;
        proxy_set_header   Connection            "upgrade";
        proxy_set_header   Host                  $host;
        proxy_set_header   X-Forwarded-For       $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto     $scheme;
        proxy_set_header   Authorization         "Bearer ${OPENCLAW_GATEWAY_TOKEN}";
        proxy_read_timeout 3600s;
    }

    location /api/ {
        rewrite            ^/api/(.*)$ /$1 break;
        proxy_pass         $gateway_api;
        proxy_set_header   Host                  $host;
        proxy_set_header   X-Real-IP             $remote_addr;
        proxy_set_header   X-Forwarded-For       $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto     $scheme;
        proxy_set_header   Authorization         "Bearer ${OPENCLAW_GATEWAY_TOKEN}";
    }

    gzip on;
    gzip_types text/css application/javascript application/json;
}
