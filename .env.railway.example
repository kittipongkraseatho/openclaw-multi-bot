# Railway gateway service
# ตั้งค่าเหล่านี้ใน service openclaw-gateway
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENCLAW_GATEWAY_TOKEN=replace-with-openssl-rand-hex-32
OPENCLAW_GATEWAY_BIND=0.0.0.0
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_CONFIG_DIR=/home/node/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/node/.openclaw/workspace

# Railway UI service
# ตั้งค่าเหล่านี้ใน service openclaw-ui
PORT=8080
GATEWAY_HOST=openclaw-gateway.railway.internal
# ต้องใช้ค่าเดียวกับ gateway service เพื่อให้ nginx proxy ใส่ Bearer token ให้ upstream
OPENCLAW_GATEWAY_TOKEN=replace-with-the-same-token-as-gateway
